{
  "name": "rt-scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "start:prod:local": "next start --port 3001",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "seed:demo": "node --env-file=.env.local scripts/seed-demo.mjs",
    "seed:functional": "node --env-file=.env.local scripts/seed-functional-demo.mjs",
    "screens:all": "node --env-file=.env.local scripts/capture-all-screens.mjs",
    "seed:users": "node --env-file=.env.local scripts/seed-users.mjs",
    "cleanup:seed-users": "node --env-file=.env.local scripts/cleanup-seed-users.mjs",
    "sync:roster": "node --env-file=.env.local scripts/sync-team-roster.mjs",
    "verify:publish": "node --env-file=.env.local scripts/verify-publish-readiness.mjs",
    "ci:local": "node scripts/local-ci-fallback.mjs",
    "ci:local:quick": "node scripts/local-ci-fallback.mjs --quick",
    "ci:local:e2e": "node scripts/local-ci-fallback.mjs --e2e",
    "auth:save": "node scripts/site-shots.mjs --save-auth true --headful true",
    "shots:sitemap": "node scripts/site-shots.mjs --mode sitemap",
    "shots:links": "node scripts/site-shots.mjs --mode links",
    "test:e2e": "playwright test",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@sentry/nextjs": "^10.40.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.7",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.6.205",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
