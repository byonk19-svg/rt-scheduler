{
  "name": "rt-scheduler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:warm": "node scripts/warm-local-routes.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "start:prod:local": "next start --port 3001",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "seed:demo": "node --env-file=.env.local scripts/seed-demo.mjs",
    "seed:demo-schedule": "node --env-file=.env.local scripts/seed-demo-schedule.mjs --confirm-demo-schedule",
    "seed:dev": "node --env-file=.env.local scripts/seed-dev.mjs",
    "seed:functional": "node --env-file=.env.local scripts/seed-functional-demo.mjs",
    "reset:e2e": "node --env-file=.env.local scripts/reset-e2e-data.mjs",
    "reset:e2e:fresh-auth": "node --env-file=.env.local scripts/reset-e2e-data.mjs --delete-auth-users",
    "screens:all": "node --env-file=.env.local scripts/capture-all-screens.mjs",
    "screens:therapist": "node --env-file=.env.local scripts/capture-therapist-validation.mjs",
    "seed:users": "node --env-file=.env.local scripts/seed-users.mjs",
    "cleanup:seed-users": "node --env-file=.env.local scripts/cleanup-seed-users.mjs",
    "cleanup:local": "node scripts/cleanup-local-artifacts.mjs",
    "sync:roster": "node --env-file=.env.local scripts/sync-team-roster.mjs",
    "verify:publish": "node --env-file=.env.local scripts/verify-publish-readiness.mjs",
    "ci:local": "node scripts/local-ci-fallback.mjs",
    "ci:local:quick": "node scripts/local-ci-fallback.mjs --quick",
    "ci:local:e2e": "node scripts/local-ci-fallback.mjs --e2e",
    "verify:quick": "node scripts/local-ci-fallback.mjs --quick",
    "verify:full": "node scripts/local-ci-fallback.mjs",
    "verify:e2e": "node scripts/local-ci-fallback.mjs --e2e",
    "typecheck": "node scripts/run-typecheck.mjs",
    "auth:save": "node scripts/site-shots.mjs --save-auth true --headful true",
    "shots:sitemap": "node scripts/site-shots.mjs --mode sitemap",
    "shots:links": "node scripts/site-shots.mjs --mode links",
    "test:e2e": "playwright test",
    "test:e2e:pickup-concurrency": "playwright test e2e/pickup-interest-concurrency.spec.ts --project=chromium --workers=1",
    "test:unit": "npm run test:unit:parallel && npm run test:unit:browser-backed",
    "test:unit:parallel": "vitest run --exclude src/components/schedule-grid/ScheduleGrid.feedback.test.ts --exclude src/components/schedule-grid/StatusCellPopover.interaction.test.ts",
    "test:unit:browser-backed": "vitest run src/components/schedule-grid/ScheduleGrid.feedback.test.ts src/components/schedule-grid/StatusCellPopover.interaction.test.ts --maxWorkers=1 --no-file-parallelism"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^16.2.6",
    "pdf-to-img": "^5.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@next/env": "^16.2.6",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "postcss": "8.5.10",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "postcss": "8.5.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
