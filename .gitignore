# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-dev/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local CLI cache
supabase/.temp/

# playwright
playwright-report/
test-results/
shots/
.auth/
.playwright-mcp/

# local screen capture and generated artifact dumps
/artifacts/

# local agent/tooling state
.agents/
.claude/
.superpowers/
.planning/
.worktrees/
security_best_practices_report.md
.tmp_lovable_import_*/
.cursor/mcp.json
.codex-dev.log
.codex-dev.err.log
.codex-start.log
.codex-start.err.log
.tmp-dev*.log
.tmp-prod*.log
.omx/
# Codex CLI: ignore local/session files; keep shared repo skills
.codex/**
!.codex/skills/
!.codex/skills/**

# local agent / dev scratch (may sit next to repo root during sessions)
.tmp/
.tmp-*
.tmp-*.json
.tmp-*.log
